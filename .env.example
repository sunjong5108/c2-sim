# Palantir Foundry OSDK integration placeholders.
# Copy this file to `.env` and fill in real values for local development.
# In Foundry Code Workspaces these are usually provided by the platform.

VITE_FOUNDRY_URL=https://your-foundry-instance.palantirfoundry.com
VITE_FOUNDRY_CLIENT_ID=your-osdk-client-id
VITE_FOUNDRY_ONTOLOGY_RID=ri.ontology.main.ontology.your-ontology-rid
